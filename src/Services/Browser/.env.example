# At least one AI provider API key is required.
# The first available model will be used as default.

# Groq (free tier, fast inference)
GROQ_API_KEY=

# Google Gemini (free tier)
GEMINI_API_KEY=

# OpenAI (paid, per-token)
OPENAI_API_KEY=

# OpenAI (ChatGPT subscription via OAuth token — run scripts/openai-login.ts to get one)
OPENAI_OAUTH_TOKEN=
OPENAI_REFRESH_TOKEN=
OPENAI_TOKEN_EXPIRATION_IN_HOURS=240

# Anthropic (paid)
ANTHROPIC_API_KEY=

# Required: which provider to use
# Valid values: groq, gemini, openai, openai-oauth, anthropic
LLM_PROVIDER=openai

# Optional: override the provider's default model
# LLM_MODEL=gpt-5.4

# Server
PORT=5040

# Browser
BROWSER_HEADLESS=false
SSRF_ALLOW_PRIVATE=true

# Optional: internal auth token for frontend → browser service calls
# BROWSER_INTERNAL_TOKEN=

# Optional: rate limiting
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=86400000

# MinIO (skill catalog storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=browserclaw-skills

# Optional: session limits
# MAX_SESSIONS=10
# MAX_SESSIONS_PER_IP=1
# SESSION_MAX_DURATION_MS=300000
# MAX_AGENT_STEPS=50
