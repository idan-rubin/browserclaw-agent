# Copy to .env and fill in for local / internal deployments.
# This file is safe to commit. Actual secret values go in .env
# (gitignored).

# Internal auth between Frontend and Browser service. Generate with:
#   openssl rand -hex 32
BROWSER_INTERNAL_TOKEN=

# MinIO (skill catalog). Defaults shown — override for production.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Internal comparison page at /compare/<COMPARE_GUID>.
#
# Both flags must be set for the route to exist. Leave unset in public
# deployments — the page returns 404 without them. The guid is a random
# opaque token; generate with:
#   openssl rand -hex 16
# Distribute the URL only to authorized users.
#
# Additionally, the browser-use sidecar is gated by a compose profile —
# start it with:
#   docker compose --profile compare up
# Plain `docker compose up` does not build or run the sidecar.
COMPARE_ENABLED=
COMPARE_GUID=

# Skill-load validation gate. When enabled, before replaying a saved
# playbook for a domain, the agent asks the LLM (one cheap, capped call)
# whether the playbook plausibly fits the user's task; if not, the skill
# is skipped and the agent learns fresh. Default: off.
# SKILL_VALIDATION_ENABLED=true

# Agent step limit. Default: 50.
# MAX_STEPS=50

# Hard ceiling on the agent step count. Any configured / requested
# maxSteps above it is clamped at loop entry (with a warning logged).
# Set to 0 to disable. Default: 100.
# MAX_STEPS_HARD_CEILING=100

# When the user fails to answer an interjection within
# USER_RESPONSE_TIMEOUT_MS, cancel the run with
# status='canceled-timeout' and emit user_interjection_timeout.
# Default false (silent continuation as before).
# INTERJECTION_TIMEOUT_CANCEL=true

# Ban a non-idempotent ref (click / type / submit / etc.) on the very
# first failure when the error message doesn't match REF_FAILURE_KEYWORDS
# and isn't transient. Default false (allow one retry as before).
# STRICT_NONIDEMPOTENT_BAN=true

# HTTP basic auth for the browser-use VNC stream (/vnc-bu). Even when
# the compare profile is running, the noVNC canvas would otherwise be
# anonymously reachable by anyone who guesses the path. Generate with:
#   htpasswd -nbB compare SOME_PASSWORD
# and double every `$` (traefik env interpolation rule).
COMPARE_VNC_BASIC_AUTH=
